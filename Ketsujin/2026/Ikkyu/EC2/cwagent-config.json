{
  "agent": {
    // 메트릭 기본 수집 주기(초)
    "metrics_collection_interval": 60,

    // 배포 리전, 예: ap-northeast-2
    "region": "__REGION__",

    // 에이전트 자체 로그 파일
    "logfile": "/opt/aws/amazon-cloudwatch-agent/logs/amazon-cloudwatch-agent.log",

    // 디버그 로그 활성화 여부
    "debug": false,

    // 에이전트 실행 계정
    "run_as_user": "root"
  },

  "metrics": {
    // CloudWatch 커스텀 메트릭 네임스페이스
    "namespace": "__NAMESPACE__",

    // 모든 메트릭에 공통으로 붙일 차원
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "InstanceType": "${aws:InstanceType}",
      "AutoScalingGroupName": "${aws:AutoScalingGroupName}"
    },

    // 메트릭 집계 기준
    "aggregation_dimensions": [
      ["AutoScalingGroupName"],
      ["InstanceId", "InstanceType"],
      []
    ],

    "metrics_collected": {
      "cpu": {
        // 모든 CPU 코어 대상
        "resources": ["*"],

        // 개별 코어가 아니라 전체 CPU 기준
        "totalcpu": true,

        // 수집할 CPU 항목
        "measurement": [
          "usage_active",
          "usage_system",
          "usage_user",
          "usage_iowait"
        ],

        "metrics_collection_interval": 60,

        // 집계 메트릭만 남기고 원본 메트릭은 제거
        "drop_original_metrics": [
          "usage_active",
          "usage_system",
          "usage_user",
          "usage_iowait"
        ]
      },

      "mem": {
        // 메모리 사용률/가용률/사용량
        "measurement": ["used_percent", "available_percent", "used"],
        "metrics_collection_interval": 60
      },

      "swap": {
        // 스왑 사용률
        "measurement": ["used_percent"],
        "metrics_collection_interval": 60
      },

      "disk": {
        // 모든 디스크/마운트포인트 대상
        "resources": ["*"],

        // 디스크 사용률, inode 여유량
        "measurement": ["used_percent", "inodes_free"],

        // 불필요한 파일시스템 제외
        "ignore_file_system_types": [
          "sysfs",
          "devtmpfs",
          "tmpfs",
          "overlay",
          "squashfs"
        ],

        // 디바이스명 대신 mount 기준 처리에 도움
        "drop_device": true,

        "metrics_collection_interval": 60,

        // 원본 메트릭 제거
        "drop_original_metrics": ["used_percent", "inodes_free"]
      },

      "diskio": {
        // 디스크 I/O 메트릭
        "resources": ["*"],
        "measurement": [
          "reads",
          "writes",
          "read_bytes",
          "write_bytes",
          "io_time"
        ],
        "metrics_collection_interval": 60
      },

      "net": {
        // 네트워크 인터페이스 메트릭
        "resources": ["*"],
        "measurement": [
          "bytes_sent",
          "bytes_recv",
          "packets_sent",
          "packets_recv",
          "drop_in",
          "drop_out"
        ],
        "metrics_collection_interval": 60
      },

      "netstat": {
        // TCP/UDP 소켓 상태 메트릭
        "measurement": ["tcp_established", "tcp_time_wait", "udp_socket"],
        "metrics_collection_interval": 60
      },

      "processes": {
        // 프로세스 상태 메트릭
        "measurement": ["running", "sleeping", "total", "zombies"],
        "metrics_collection_interval": 60
      }
    }
  },

  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            // 시스템 로그 경로
            "file_path": "__SYSTEM_LOG_PATH__",

            // 저장할 CloudWatch Logs 그룹명
            "log_group_name": "__LOG_GROUP_SYSTEM__",

            // 로그 스트림명, 인스턴스 ID 포함
            "log_stream_name": "{instance_id}-system",

            // 타임존
            "timezone": "Local"
          },
          {
            // 애플리케이션 로그 경로
            "file_path": "__APP_LOG_PATH__",

            // 앱 로그 그룹명
            "log_group_name": "__LOG_GROUP_APP__",

            // 앱 로그 스트림명
            "log_stream_name": "{instance_id}-app",

            "timezone": "Local"
          },
          {
            // 웹 access 로그 경로
            "file_path": "__WEB_ACCESS_LOG_PATH__",

            "log_group_name": "__LOG_GROUP_WEB_ACCESS__",
            "log_stream_name": "{instance_id}-access",
            "timezone": "Local"
          },
          {
            // 웹 error 로그 경로
            "file_path": "__WEB_ERROR_LOG_PATH__",

            "log_group_name": "__LOG_GROUP_WEB_ERROR__",
            "log_stream_name": "{instance_id}-error",
            "timezone": "Local"
          }
        ]
      }
    }
  }
}